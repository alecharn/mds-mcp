# ---------------------------------------------------------------------------
# MDS MCP server configuration
#
# Copy this file to `.env` and fill in your switches.
# ---------------------------------------------------------------------------

# --- Transport -------------------------------------------------------------
MCP_TRANSPORT=http      # "stdio" or "http"
MCP_HOST=0.0.0.0        # http only: bind address
MCP_PORT=8000           # http only: bind port

# --- Switch #1 -------------------------------------------------------------
MDS_1_NAME=mds-fab-a    # optional: friendly name (defaults to the host)
MDS_1_HOST=192.0.2.10   # required: IP or hostname
MDS_1_USERNAME=admin    # required
MDS_1_PASSWORD=changeme # required
MDS_1_PORT=8443         # optional: NX-API HTTPS port (default 8443)
MDS_1_VERIFY_SSL=false  # optional: verify TLS cert (default false)

# --- Switch #2 -------------------------------------------------------------
# Add as many switches as you want by repeating the block with the next number.
MDS_2_NAME=mds-fab-b
MDS_2_HOST=192.0.2.11
MDS_2_USERNAME=admin
MDS_2_PASSWORD=changeme

# --- Switch #3 -------------------------------------------------------------
# MDS_3_NAME=mds-fab-c
# MDS_3_HOST=192.0.2.12
# MDS_3_USERNAME=admin
# MDS_3_PASSWORD=changeme
